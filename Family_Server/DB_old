    public boolean fileBelongsToUser(String fileName, int userId) {
        // Determine which table to query based on file extension
        String table;
        String lower = fileName.toLowerCase();

        if (lower.endsWith(".mp4") || lower.endsWith(".avi") ||
            lower.endsWith(".mov") || lower.endsWith(".mkv")) {
            table = "videos";
        } else {
            table = "photos";
        }

        // Check both file_name and saved_path columns
        String sql = "SELECT COUNT(*) FROM " + table +
            " WHERE (file_name = ? OR saved_path LIKE ?) AND user_id = ?";

        try (PreparedStatement ps = sharedConn.prepareStatement(sql)) {
            ps.setString(1, fileName);
            ps.setString(2, "%" + fileName);
            ps.setInt(3, userId);

            ResultSet rs = ps.executeQuery();
            boolean exists = rs.next() && rs.getInt(1) > 0;

            if (!exists) {
                System.out.println("⚠️ No DB match for file: " + fileName + " (user_id=" + userId + ", table=" + table + ")");
            }

            return exists;

        } catch (SQLException e) {
            System.err.println("⚠️ fileBelongsToUser check failed: " + e.getMessage());
            return false;
        }
    }





