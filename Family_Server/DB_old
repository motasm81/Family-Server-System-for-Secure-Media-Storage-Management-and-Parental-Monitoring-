public class DatabaseManager {
    public static final String DB_PATH = "F:/Server_Storage/family_server.db";
    static Connection sharedConn;
    private static final Object lock = new Object();

    // ✅ Constructor ensures connection + initialization only once
    public DatabaseManager() {
        try {
            if (sharedConn == null || sharedConn.isClosed()) {
                System.out.println("[DatabaseManager] Loading SQLite JDBC driver...");
                Class.forName("org.sqlite.JDBC");

                System.out.println("[DatabaseManager] Connecting to: " + DB_PATH);
                sharedConn = DriverManager.getConnection("jdbc:sqlite:" + DB_PATH);

                System.out.println("[DatabaseManager] ✅ Database connected successfully!");

                // ✅ Always initialize tables immediately
                initDatabase();

            } else {
                System.out.println("[DatabaseManager] ℹ️ Reusing existing DB connection.");
            }
        } catch (Exception e) {
            System.err.println("[DatabaseManager] ❌ Exception in constructor: " + e.getMessage());
            e.printStackTrace();
        }
    }

    // ✅ Shared connection getter
    public static Connection getConnection() throws SQLException {
        return DriverManager.getConnection("jdbc:sqlite:" + DB_PATH);
    }


    public static Connection getNewConnection() throws SQLException {
        return DriverManager.getConnection("jdbc:sqlite:" + DB_PATH);
    }

    // ✅ Guaranteed single initialization
    public static void initDatabase() {
        try {
            if (sharedConn == null || sharedConn.isClosed()) {
                System.err.println("[DatabaseManager] ❌ initDatabase called but sharedConn is null!");
                return;
            }

            synchronized (lock) {
                try (Statement stmt = sharedConn.createStatement()) {

                    // === USERS TABLE (NEW - QR pairing compatible) ===
                    stmt.executeUpdate("""
    CREATE TABLE IF NOT EXISTS users (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        username TEXT UNIQUE,
        password TEXT NOT NULL,
        role TEXT CHECK(role IN ('parent', 'child')) NOT NULL,
        device_name TEXT,
        device_mac TEXT UNIQUE,
        device_serial TEXT UNIQUE,
        device_uuid TEXT UNIQUE,
        created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )
""");
                    stmt.execute("""
    CREATE TABLE IF NOT EXISTS device_stats (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        username TEXT,
        battery INTEGER,
        free_storage INTEGER,
        os_version TEXT,
        device_model TEXT,
        app_version TEXT,
        timestamp LONG
    )
""");




                    // === PHOTOS TABLE ===
                    stmt.executeUpdate("""
                    CREATE TABLE IF NOT EXISTS photos (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      file_name TEXT NOT NULL,
                      file_size TEXT,
                      date_taken TEXT,
                      saved_path TEXT,
                      user_id INTEGER NOT NULL REFERENCES users(id),
                      upload_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                    )
                """);

                    // === VIDEOS TABLE ===
                    stmt.executeUpdate("""
                    CREATE TABLE IF NOT EXISTS videos (
                      id INTEGER PRIMARY KEY AUTOINCREMENT,
                      file_name TEXT NOT NULL,
                      file_size TEXT,
                      date_taken TEXT,
                      saved_path TEXT,
                      user_id INTEGER NOT NULL REFERENCES users(id),
                      upload_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP
                    )
                """);

                    // === PHOTO CAPTION TABLE ===
                    stmt.executeUpdate("""
                    CREATE TABLE IF NOT EXISTS photosCaption (
                        id INTEGER PRIMARY KEY AUTOINCREMENT,
                        file_name TEXT NOT NULL,
                        caption TEXT
                    )
                """);

                    // === VIDEO CAPTION TABLE ===
                    stmt.executeUpdate("""
                    CREATE TABLE IF NOT EXISTS videoCaptions (
                        id INTEGER PRIMARY KEY AUTOINCREMENT,
                        file_name TEXT NOT NULL,
                        caption TEXT
                    )
                """);
                    stmt.executeUpdate("""
CREATE TABLE IF NOT EXISTS app_usage (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT NOT NULL,
    package_name TEXT NOT NULL,
    app_name TEXT NOT NULL,
    usage_time_ms LONG NOT NULL,
    start_time LONG NOT NULL,
    end_time LONG NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
)
""");

                    stmt.executeUpdate("""
CREATE TABLE IF NOT EXISTS screen_time (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT NOT NULL,
    total_screen_time_ms LONG NOT NULL,
    day DATE NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    UNIQUE(username, day)
)
""");


                    System.out.println("[DatabaseManager] ✅ SQLite tables initialized successfully at: " + DB_PATH);
                }

                // Confirm users table exists
                try (ResultSet rs = sharedConn.getMetaData().getTables(null, null, "users", null)) {
                    if (rs.next()) {
                        System.out.println("[DatabaseManager] ✅ 'users' table confirmed in database.");
                    } else {
                        System.err.println("[DatabaseManager] ❌ 'users' table missing after init!");
                    }
                }
            }

        } catch (SQLException e) {
            System.err.println("[DatabaseManager] ❌ DB init error: " + e.getMessage());
            e.printStackTrace();
        }
    }

