    public static boolean fileExists(String fileName) {
        String sqlPhoto = "SELECT 1 FROM photos WHERE file_name = ? LIMIT 1";
        String sqlVideo = "SELECT 1 FROM videos WHERE file_name = ? LIMIT 1";

        synchronized (lock) {
            try (PreparedStatement pstmtPhoto = sharedConn.prepareStatement(sqlPhoto)) {
                pstmtPhoto.setString(1, fileName);
                try (ResultSet rs = pstmtPhoto.executeQuery()) {
                    if (rs.next()) return true;
                }
            } catch (SQLException e) {
                System.err.println("DB error checking photo existence: " + e.getMessage());
            }

            try (PreparedStatement pstmtVideo = sharedConn.prepareStatement(sqlVideo)) {
                pstmtVideo.setString(1, fileName);
                try (ResultSet rs = pstmtVideo.executeQuery()) {
                    if (rs.next()) return true;
                }
            } catch (SQLException e) {
                System.err.println("DB error checking video existence: " + e.getMessage());
            }
        }
        return false;
    }



    public static String getFilePath(String fileName) {
        String sqlPhoto = "SELECT saved_path FROM photos WHERE file_name = ? LIMIT 1";
        String sqlVideo = "SELECT saved_path FROM videos WHERE file_name = ? LIMIT 1";

        synchronized (lock) {
            try (PreparedStatement pstmtPhoto = sharedConn.prepareStatement(sqlPhoto)) {
